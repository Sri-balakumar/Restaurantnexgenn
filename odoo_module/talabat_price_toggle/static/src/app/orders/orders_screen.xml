<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Add Token Number column to TicketScreen orders list -->
    <t t-name="point_of_sale.TicketScreen" t-inherit="point_of_sale.TicketScreen" t-inherit-mode="extension">

        <!-- Add Token column in desktop view (after receipt number column - td[2]) -->
        <xpath expr="//tr[@class='order-row']/td[2]" position="after">
            <td class="align-middle">
                <div class="fw-bolder text-primary"><t t-esc="getTokenNumber(order)"/></div>
            </td>
        </xpath>

        <!-- Add Token to mobile view (after order name div) -->
        <xpath expr="//div[@class='p-2 d-flex flex-column flex-grow-1 justify-content-center align-items-start']/div[@class='small text-muted']" position="after">
            <div class="small text-muted">Token: <span class="text-primary fw-bold"><t t-esc="getTokenNumber(order)"/></span></div>
        </xpath>

    </t>

</templates>
