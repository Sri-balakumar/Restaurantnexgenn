<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Token Number to POS Order Tree View -->
    <record id="view_pos_order_tree_inherit_token" model="ir.ui.view">
        <field name="name">pos.order.tree.inherit.token</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_tree"/>
        <field name="arch" type="xml">
            <!-- Add Token Number column after the Order Reference -->
            <xpath expr="//field[@name='name']" position="after">
                <field name="token_number" string="Token Number" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Add Token Number and Pickup Date to POS Order Form View -->
    <record id="view_pos_order_form_inherit_token" model="ir.ui.view">
        <field name="name">pos.order.form.inherit.token</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <!-- Add Token Number and Pickup Date in the header area -->
            <xpath expr="//field[@name='name']" position="after">
                <field name="token_number" readonly="1"/>
                <field name="pickup_date"/>
            </xpath>
        </field>
    </record>

    <!-- Add Token Number to search view for filtering -->
    <record id="view_pos_order_search_inherit_token" model="ir.ui.view">
        <field name="name">pos.order.search.inherit.token</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_order_search"/>
        <field name="arch" type="xml">
            <!-- Add Token Number and Pickup Date to search fields -->
            <xpath expr="//field[@name='name']" position="after">
                <field name="token_number" string="Token Number" filter_domain="[('token_number', 'ilike', self)]"/>
                <field name="pickup_date" string="Pickup Date" filter_domain="[('pickup_date', 'ilike', self)]"/>
            </xpath>
        </field>
    </record>
</odoo>
