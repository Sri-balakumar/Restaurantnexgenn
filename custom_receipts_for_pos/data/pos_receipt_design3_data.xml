<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">
    <!-- Custom design with POS logo and QR code support (based on OLD Design 1) -->
    <record id="pos_receipt_custom_design" model="pos.receipt" forcecreate="0">
        <field name="name">custom design</field>
        <field name="design_receipt"><![CDATA[

        <div class="pos-receipt">
            <!-- Logo Section -->
            <t t-if="env.services.pos.config.pos_logo">
                <div style="text-align:center;">
                    <img t-att-src="'data:image/png;base64,' + env.services.pos.config.pos_logo"
                         alt="Logo" style="max-width: 200px; max-height: 90px;"/>
                </div>
             </t>

            <!-- Company Info -->
            <div class="pos-receipt-contact" style="text-align:center; width:95%; max-width:95%; margin:0 auto; padding:0 2px; box-sizing:border-box;">
                <!-- Company Address -->
                <t t-if="env.services.pos.company.street or env.services.pos.company.street2">
                    <div style="word-wrap:break-word; font-size:12px; line-height:1.3;">
                        <t t-if="env.services.pos.company.street">
                            <t t-esc="env.services.pos.company.street" />
                        </t>
                        <t t-if="env.services.pos.company.street2">
                            <t t-if="env.services.pos.company.street">, </t>
                            <t t-esc="env.services.pos.company.street2" />
                        </t>
                    </div>
                </t>
                <div style="word-wrap:break-word; font-size:12px; line-height:1.3;">
                    <t t-if="env.services.pos.company.city">
                        <t t-esc="env.services.pos.company.city" />
                    </t>
                    <t t-if="env.services.pos.company.state_id">
                        , <t t-esc="env.services.pos.company.state_id.name" />
                    </t>
                    <t t-if="env.services.pos.company.zip">
                        - <t t-esc="env.services.pos.company.zip" />
                    </t>
                </div>
                <t t-if="env.services.pos.company.country_id">
                    <div style="word-wrap:break-word; font-size:12px; line-height:1.3;">
                        <t t-esc="env.services.pos.company.country_id.name" />
                    </div>
                </t>
                <t t-if="env.services.pos.company.phone">
                    <div style="font-size:12px; line-height:1.3;">
                        Tel: <t t-esc="env.services.pos.company.phone" />
                    </div>
                </t>
                <t t-if="env.services.pos.company.vat">
                    <div style="font-size:11px; line-height:1.3;">
                        C.R: <t t-esc="env.services.pos.company.vat" />
                    </div>
                </t>
            </div>

            <!-- TAX INVOICE Header (Bilingual) -->
            <div style="text-align:center; font-size:16px; font-weight:bold; padding:8px 0; border-top:1px solid #000; border-bottom:1px solid #000; margin-top:10px; margin-bottom:10px;">
                TAX INVOICE / فاتورة ضريبية
            </div>

            <!-- Bill Details: No, Cashier, Date, Time -->
            <div style="font-size:13px; line-height:1.8; margin-bottom:10px;">
                <div style="display:flex; justify-content:space-between;">
                    <span><strong>No:</strong> <t t-esc="props.order.name.split('-').pop().trim()"/></span>
                </div>
                <div style="display:flex; justify-content:space-between;">
                    <span><strong>Cashier:</strong> <t t-esc="props.header.cashier"/></span>
                </div>
                <div style="display:flex; justify-content:space-between;">
                    <span><strong>Date:</strong> <t t-esc="new Date().toLocaleDateString('en-GB')"/></span>
                    <span style="direction:rtl;">:التاريخ</span>
                </div>
                <div style="display:flex; justify-content:space-between;">
                    <span><strong>Time:</strong> <t t-esc="new Date().toLocaleTimeString('en-GB', {hour: '2-digit', minute: '2-digit'})"/></span>
                    <span style="direction:rtl;">:الوقت</span>
                </div>
            </div>

            <!-- Separator Line -->
            <div style="border-bottom:1px solid #000; margin:10px 0;"></div>
            <div>
                <table class='receipt-orderlines' style="font-size:13px; border-collapse:collapse; width:100%;">
                    <colgroup>
                        <col width='10%' />
                        <col width='40%' />
                        <col width='20%' />
                        <col width='30%' />
                    </colgroup>
                    <thead>
                        <tr style="border-top:1px solid #000; border-bottom:1px solid #000;">
                            <th style="text-align:center; padding:5px 2px;">
                                <strong>Serial No</strong><br/>
                                <span style="font-size:10px; font-weight:normal; direction:rtl;">الرقم التسلسلي</span>
                            </th>
                            <th style="text-align:center; padding:5px 2px;">
                                <strong>Product Name</strong><br/>
                                <span style="font-size:10px; font-weight:normal; direction:rtl;">اسم المنتج</span>
                            </th>
                            <th style="text-align:center; padding:5px 2px;">
                                <strong>Qty</strong><br/>
                                <span style="font-size:10px; font-weight:normal; direction:rtl;">كمية</span>
                            </th>
                            <th style="text-align:center; padding:5px 2px;">
                                <strong>Unit Price</strong><br/>
                                <span style="font-size:10px; font-weight:normal; direction:rtl;">سعر الوحدة</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-if="props.order.lines">
                            <tr t-foreach="props.order.lines" t-as="line" t-key="line.id" style="border-bottom:1px dashed #000;">
                                <td style="padding:8px 2px; text-align:center; font-size:13px;">
                                    <t t-esc="line_index + 1"/>
                                </td>
                                <td style="padding:8px 2px; text-align:center; font-size:13px;">
                                    <t t-esc="line.product_id.display_name"/>
                                    <t t-if="line.discount > 0">
                                        <div style="font-size:11px; font-style:italic; color:#666;">
                                            <t t-esc="line.discount"/>% discount
                                        </div>
                                    </t>
                                    <t t-if="line.customer_note">
                                        <div style="font-size:11px; color:#444;" t-esc="line.customer_note"/>
                                    </t>
                                </td>
                                <td style="padding:8px 2px; text-align:center; font-size:13px;">
                                    <t t-esc="line.qty"/>
                                </td>
                                <td style="padding:8px 2px; text-align:center; font-size:13px;">
                                    <t t-esc="props.formatCurrency(line.price_subtotal_incl)"/>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>

            <!-- Bottom Border for Table -->
            <div style="border-bottom:1px solid #000; margin-top:0;"></div>

            <!-- Totals Section (Bilingual) -->
            <div style="padding-top:5px; font-size:14px;">
                <t t-set="taxTotals" t-value="props.order.taxTotals"/>

                <!-- Always show Subtotal -->
                <div style="display:flex; justify-content:space-between; padding:3px 0;">
                    <span>
                        <strong>Subtotal / المجموع</strong><br/>
                        <span style="font-size:11px; direction:rtl;">:الفرع ي</span>
                    </span>
                    <span style="direction:ltr;">
                        <t t-esc="props.formatCurrency(taxTotals?.subtotals?.[0]?.base_amount_currency || props.order.amount_total)"/>
                    </span>
                </div>

                <!-- Always show Tax (even if 0) -->
                <t t-if="taxTotals and taxTotals.has_tax_groups">
                    <!-- Show each tax group -->
                    <t t-foreach="taxTotals.subtotals[0]?.tax_groups || []" t-as="tax_group" t-key="tax_group.id">
                        <div style="display:flex; justify-content:space-between; padding:3px 0;">
                            <span>
                                <strong>Tax / ضريبة</strong><br/>
                                <span style="font-size:11px; direction:rtl;">:<t t-esc="tax_group.group_name" /></span>
                            </span>
                            <span style="direction:ltr;">
                                <t t-esc="props.formatCurrency(tax_group.tax_amount_currency)"/>
                            </span>
                        </div>
                    </t>
                </t>
                <t t-else="">
                    <!-- No tax groups - show 0 -->
                    <div style="display:flex; justify-content:space-between; padding:3px 0;">
                        <span>
                            <strong>Tax / ضريبة</strong><br/>
                            <span style="font-size:11px; direction:rtl;">:ضريبة</span>
                        </span>
                        <span style="direction:ltr;">
                            <t t-esc="props.formatCurrency(0)"/>
                        </span>
                    </div>
                </t>

                <!-- Grand Total -->
                <div style="border-top:1px solid #000; border-bottom:1px solid #000; margin:5px 0 0 0; padding:5px 0;">
                    <div style="display:flex; justify-content:space-between; font-weight:bold; font-size:16px;">
                        <span>TOTAL</span>
                        <span style="direction:ltr;">
                            <t t-esc="props.formatCurrency(props.order.amount_total)"/>
                        </span>
                    </div>
                </div>
            </div>
            <div class='before-footer' />

            <!-- QR Code Section (Smaller, No Border) -->
            <t t-if="env.services.pos.config.show_qr_code and env.services.pos.config.qr_code_image">
                <div style="text-align:center; padding:10px 0;">
                    <div style="font-weight:600; font-size:13px; margin-bottom:8px;">
                        Scan QR Code
                    </div>
                    <div style="display:inline-block;">
                        <img t-att-src="'data:image/png;base64,' + env.services.pos.config.qr_code_image"
                             alt="QR Code"
                             style="width:130px; height:130px;"/>
                    </div>
                </div>
            </t>

            <!-- Thank You Message -->
            <div style="font-size:13px; text-align:center; margin-top:15px; padding-top:10px; border-top:1px dashed #000;">
                Thank You... Please Visit Again ...
            </div>
        </div>]]></field>
    </record>
</odoo>
