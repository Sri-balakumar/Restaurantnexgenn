<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Examples for receipt design: which can be used or modified -->
    <record id="pos_receipt_design2_demo" model="pos.receipt">
        <field name="name">Design 2</field>
        <field name="design_receipt"><![CDATA[

        <div class="pos-receipt">
            <t t-if="env.services.pos.config.logo">
                <img t-att-src="'data:image/png;base64,' + env.services.pos.config.logo"
                     alt="Logo" class="pos-receipt-logo"/>
                <br />
             </t>
            <div style="font-size:13px; text-align:center;">
                <t t-esc="env.services.pos.company.name"/><br />
                Phone:<t t-esc="env.services.pos.company.phone || ''"/><br />
            </div>
            <br/>
            <div style="font-size:13px; text-align:center;">
                Date: <t t-esc="props.order.date?.toLocaleString() || ''"/><br />
                Order: <t t-esc="props.order.name"/><br />
            </div>
            <br />
            <div style="font-size:13px; text-align:center;">
                Cashier: <t t-esc="props.header.cashier" /><br />
                <t t-if="props.order.partner_id">
                    Customer: <t t-esc="props.order.partner_id.name" style="font-style:bold" />
                </t>
                <br />
            </div>
            <br/>
            <t t-if="props.header.header">
                <div style='text-align:center; font-size:13px'>
                    <t t-esc="props.header.header" />
                </div>
                <br />
            </t>
            <div>
                <table class='receipt-orderlines' style="font-size:15px; border-style:double;
            border-left:none; border-right:none; border-bottom:none; width:100%;">
                <colgroup>
                    <col width='40%' />
                    <col width='30%' />
                    <col width='30%' />
                </colgroup>
                <tr style="border-bottom:1px dashed black;">
                    <th style="text-align:left;">Product</th>
                    <th style="text-align:right;">Qty</th>
                    <th style="text-align:right;">Amount</th>
                </tr>
                <t t-if="props.order.lines">
                    <tr t-foreach="props.order.lines" t-as="line" t-key="line.id">
                        <td style="padding-top:1%; padding-bottom:1%; text-align:left;">
                            <t t-esc="line.product_id.display_name"/>
                            <t t-if="line.discount > 0">
                                <div style="font-size:12px; font-style:italic; color:#808080;">
                                    <t t-esc="line.discount"/>% discount
                                </div>
                            </t>
                            <t t-if="line.customer_note">
                                <div style="font-size:14px;" t-esc="line.customer_note"/>
                            </t>
                        </td>
                        <td style="text-align:right; font-size:14px;">
                            <t t-esc="line.qty"/>
                        </td>
                        <td style="text-align:right; font-size:14px;">
                            <t t-esc="props.formatCurrency(line.price_subtotal_incl)"/>
                        </td>
                    </tr>
                </t>
                </table>
            </div>
            <br />
            <div style="padding-top:6px;">
                <t t-set="taxTotals" t-value="props.order.taxTotals"/>
                <t t-if="taxTotals and taxTotals.has_tax_groups">
                    <br/>
                    <div style="font-weight:700; font-size:14px; border-top:1px dashed;">
                        <span style="margin-left:40%;">Subtotal : </span>
                        <span t-esc="props.formatCurrency(taxTotals.subtotals[0]?.base_amount_currency || 0)" class="pos-receipt-right-align"/>
                    </div>
                    <t t-foreach="taxTotals.subtotals[0]?.tax_groups || []" t-as="tax_group" t-key="tax_group.id">
                        <div style="font-weight:700; font-size:14px;">
                            <span style="margin-left:40%;"><t t-esc="tax_group.group_name" /></span>
                            <span t-esc="props.formatCurrency(tax_group.tax_amount_currency)" class="pos-receipt-right-align"/>
                        </div>
                    </t>
                </t>
                <!-- Total -->
                <br/>
                <div style="font-weight:700; font-size:14px;">
                    <span style="margin-left:40%;">TOTAL : </span>
                    <span t-esc="props.formatCurrency(props.order.amount_return)" class="pos-receipt-right-align"/>
                </div>
                <br/><br/>
            </div>
            <!-- Payment Lines -->
            <t t-foreach="props.paymentLines" t-as="line" t-key="line.id">
                <div style="font-size:14px; border-top:1px dashed; padding-top:5px;">
                    <span style="margin-left:40%;"><t t-esc="line.payment_method_id.name" /></span>
                    <span t-esc="props.formatCurrency(line.amount)" class="pos-receipt-right-align"/>
                </div>
            </t>
            <br/>
            <div class="receipt-change" style="font-size:14px;">
                <span style="margin-left:40%;">CHANGE : </span>
                <span t-esc="props.formatCurrency(props.order.amount_return)" class="pos-receipt-right-align"/>
            </div>
            <br/>
            <!-- Extra Payment Info -->
            <t t-set="totalDiscount" t-value="props.order.get_total_discount()" />
            <t t-if="totalDiscount">
                <div style="font-size:14px; border-top:1px dashed; padding-top:5px;">
                    <span style="margin-left:40%;">Discounts : </span>
                    <span t-esc="props.formatCurrency(totalDiscount)" class="pos-receipt-right-align"/>
                </div>
            </t>
            <div class='before-footer' />
            <!-- Footer -->
            <t t-if="props.order.config.receipt_footer">
                <div style="text-align:center; font-size:14px;">
                    <br/>
                    <t t-esc="props.order.config.receipt_footer"/>
                    <br/><br/>
                </div>
            </t>
            <div class='after-footer' style="font-size:14px;">
                <t t-foreach="props.paymentLines" t-as="line" t-key="line.id">
                    <t t-if="line.ticket">
                        <br />
                        <div class="pos-payment-terminal-receipt">
                            <t t-raw="line.ticket"/>
                        </div>
                    </t>
                </t>
            </div>
            <br/><br/>
            <div style="font-size:14px; text-align:center;">
                Thank You... Please Visit Again ...
            </div>
        </div>]]></field>
    </record>
</odoo>