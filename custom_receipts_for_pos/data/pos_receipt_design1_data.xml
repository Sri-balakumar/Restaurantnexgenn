<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_receipt_design_80mm" model="pos.receipt">
        <field name="name">80mm Thermal Receipt</field>
        <field name="design_receipt"><![CDATA[
<div class="pos-receipt" style="width:80mm; font-family:Arial,sans-serif; font-size:9px; padding:3mm; margin:0; box-sizing:border-box;">
    
    <t t-set="company" t-value="env.services.pos.company"/>
    
    <!-- Company Header -->
    <div style="text-align:center; font-size:20px; font-weight:bold; margin-bottom:2mm;">
        <t t-esc="company.name" />
    </div>
    
    <div style="text-align:center; font-size:9px; margin-bottom:1mm;">
        <t t-if="company.city" t-esc="company.city"/><br/>
        <t t-if="company.country_id" t-esc="company.country_id.name"/>
    </div>
    
    <div style="text-align:center; font-size:8px; margin-bottom:1mm;">
        <t t-if="company.vat">VAIN: <t t-esc="company.vat"/></t>
    </div>
    
    <div style="text-align:center; font-size:9px; margin-bottom:2mm; direction:rtl;">
        ريحانة المواخج للتسويق
    </div>
    
    <!-- Invoice Header -->
    <div style="text-align:center; font-size:10px; font-weight:bold; padding:2mm 0; border-top:2px solid black; border-bottom:2px solid black; margin:2mm 0;">
        Simplified Tax Invoice / فاتورة ضريبية
    </div>
    
    <div style="font-size:8.5px; margin:1mm 0;">
        <div style="text-align:right;">No: <t t-esc="props.order.name.split('-').pop().trim()"/></div>
        <div style="border-bottom:1px solid black; padding:1mm 0;">Cashier: <t t-esc="props.header.cashier"/></div>
    </div>
    
    <!-- Product Table Header -->
    <table style="width:100%; border-collapse:collapse; font-size:7px; margin-top:2mm; border-top:2px solid black; border-bottom:1px solid black;">
        <thead>
            <tr style="background:#f0f0f0;">
                <th style="padding:2mm 1mm; text-align:left; border-right:1px solid black; width:30%;">
                    <strong>Product Name</strong><br/>
                    <span style="font-size:6px; direction:rtl;">اسم المنتج</span>
                </th>
                <th style="padding:2mm 1mm; text-align:center; border-right:1px solid black; width:12%;">
                    <strong>Qty</strong><br/>
                    <span style="font-size:6px; direction:rtl;">كمية</span>
                </th>
                <th style="padding:2mm 1mm; text-align:center; border-right:1px solid black; width:20%;">
                    <strong>Unit Price</strong><br/>
                    <span style="font-size:6px; direction:rtl;">سعر الوحدة</span>
                </th>
                <th style="padding:2mm 1mm; text-align:center; border-right:1px solid black; width:15%;">
                    <strong>Tax</strong><br/>
                    <span style="font-size:6px; direction:rtl;">الضريبة</span>
                </th>
                <th style="padding:2mm 1mm; text-align:center; width:23%;">
                    <strong>Total</strong><br/>
                    <span style="font-size:6px; direction:rtl;">المجموع</span>
                </th>
            </tr>
        </thead>
    </table>
    
    <!-- Product Lines -->
    <t t-if="props.order.lines">
        <t t-foreach="props.order.lines" t-as="line" t-key="line.id">
            <div style="margin-top:2mm; padding:1mm; background:#fafafa;">
                <div style="font-size:8px; font-weight:bold;">
                    <t t-esc="line_index + 1"/>. <t t-esc="line.product_id.default_code || ''"/>
                </div>
                <div style="font-size:7px; color:#666;">
                    <t t-esc="line.product_id.barcode || ''"/>
                </div>
                
                <table style="width:100%; border-collapse:collapse; font-size:8px; margin-top:1mm; border-bottom:1px dashed #ccc;">
                    <tr>
                        <td style="padding:1mm; width:30%; word-wrap:break-word;">
                            <t t-esc="line.product_id.display_name"/>
                        </td>
                        <td style="padding:1mm; text-align:center; width:12%;">
                            <t t-esc="line.qty"/>
                        </td>
                        <td style="padding:1mm; text-align:center; width:20%;">
                            <t t-esc="line.price_unit.toFixed(3)"/>
                        </td>
                        <td style="padding:1mm; text-align:center; width:15%;">
                            <t t-esc="(line.price_subtotal_incl - line.price_subtotal).toFixed(3)"/>
                        </td>
                        <td style="padding:1mm; text-align:right; width:23%; font-weight:bold;">
                            <t t-esc="line.price_subtotal_incl.toFixed(3)"/>
                        </td>
                    </tr>
                </table>
            </div>
        </t>
    </t>
    
    <!-- Totals Section -->
    <div style="border-top:2px solid black; margin-top:3mm; padding-top:2mm;">
        <table style="width:100%; font-size:9px;">
            <tr>
                <td style="padding:1mm; text-align:right; width:60%;">Total (Excl Vat):</td>
                <td style="padding:1mm; text-align:right; width:40%; font-weight:bold;">
                    <t t-esc="props.formatCurrency(props.order.amount_total - props.order.amount_tax)"/>
                </td>
            </tr>
            <tr>
                <td style="padding:1mm; text-align:right;">Total Vat:</td>
                <td style="padding:1mm; text-align:right; font-weight:bold;">
                    <t t-esc="props.formatCurrency(props.order.amount_tax)"/>
                </td>
            </tr>
            <tr style="border-top:1px solid black;">
                <td style="padding:1mm; text-align:right; font-size:10px; font-weight:bold;">Total (Incl Vat):</td>
                <td style="padding:1mm; text-align:right; font-size:10px; font-weight:bold;">
                    <t t-esc="props.formatCurrency(props.order.amount_total)"/>
                </td>
            </tr>
        </table>
    </div>
    
    <!-- Tax Table -->
    <div style="border-top:2px solid black; margin-top:2mm; padding-top:2mm;">
        <table style="width:100%; border-collapse:collapse; font-size:8px; border:1px solid black;">
            <tr style="background:#f0f0f0; border-bottom:1px solid black;">
                <th style="padding:1.5mm; text-align:center; width:20%; border-right:1px solid black;">Tax %</th>
                <th style="padding:1.5mm; text-align:center; width:40%; border-right:1px solid black;">Taxable Amount</th>
                <th style="padding:1.5mm; text-align:center; width:40%;">Tax Amount</th>
            </tr>
            <t t-set="taxTotals" t-value="props.order.taxTotals"/>
            <t t-if="taxTotals and taxTotals.has_tax_groups">
                <t t-foreach="taxTotals.subtotals[0]?.tax_groups || []" t-as="tax_group" t-key="tax_group.id">
                    <tr>
                        <td style="padding:1.5mm; text-align:center; border-right:1px solid black;">
                            Tax <t t-esc="tax_group.group_name"/>
                        </td>
                        <td style="padding:1.5mm; text-align:center; border-right:1px solid black;">
                            <t t-esc="(tax_group.base_amount_currency || 0).toFixed(3)"/>
                        </td>
                        <td style="padding:1.5mm; text-align:center;">
                            <t t-esc="tax_group.tax_amount_currency.toFixed(3)"/>
                        </td>
                    </tr>
                </t>
            </t>
            <t t-else="">
                <tr>
                    <td style="padding:1.5mm; text-align:center; border-right:1px solid black;">0.00</td>
                    <td style="padding:1.5mm; text-align:center; border-right:1px solid black;">
                        <t t-esc="(props.order.amount_total - props.order.amount_tax).toFixed(3)"/>
                    </td>
                    <td style="padding:1.5mm; text-align:center;">0.000</td>
                </tr>
            </t>
            <tr style="border-top:1px solid black; font-weight:bold;">
                <td style="padding:1.5mm; border-right:1px solid black;"></td>
                <td style="padding:1.5mm; text-align:center; border-right:1px solid black;">
                    <t t-esc="(props.order.amount_total - props.order.amount_tax).toFixed(3)"/>
                </td>
                <td style="padding:1.5mm; text-align:center;">
                    <t t-esc="props.order.amount_tax.toFixed(3)"/>
                </td>
            </tr>
        </table>
    </div>
    
    <!-- Payment Details -->
    <div style="border-top:3px double black; margin-top:2mm; padding-top:2mm;">
        <div style="text-align:center; font-size:9px; font-weight:bold; text-decoration:underline; margin-bottom:2mm;">
            Payment Details
        </div>
        
        <table style="width:100%; font-size:8.5px;">
            <t t-foreach="props.paymentLines" t-as="payline" t-key="payline.id">
                <tr>
                    <td style="padding:1mm; text-align:right; width:60%;">
                        <t t-esc="payline.payment_method_id.name"/> / <span style="direction:rtl;">نقداً</span>:
                    </td>
                    <td style="padding:1mm; text-align:right; width:40%; font-weight:bold;">
                        <t t-esc="props.formatCurrency(payline.amount)"/>
                    </td>
                </tr>
            </t>
            <tr>
                <td style="padding:1mm; text-align:right;">
                    Tender Cash / <span style="direction:rtl;">المبلغ المستلم</span>:
                </td>
                <td style="padding:1mm; text-align:right; font-weight:bold;">
                    <t t-esc="props.formatCurrency(props.order.amount_total)"/>
                </td>
            </tr>
            <tr>
                <td style="padding:1mm; text-align:right;">
                    Balance Cash / <span style="direction:rtl;">المبلغ المتبقي</span>:
                </td>
                <td style="padding:1mm; text-align:right; font-weight:bold;">
                    <t t-esc="props.formatCurrency(props.order.amount_return || 0)"/>
                </td>
            </tr>
        </table>
        
        <div style="margin-top:2mm; font-weight:bold;">
            Total Qty: <span style="font-size:10px;"><t t-esc="props.order.lines.length"/></span>
        </div>
    </div>
    
    <!-- Footer -->
    <div style="border-top:2px solid black; margin-top:2mm; padding-top:2mm;">
        <div style="text-align:center; font-size:8.5px; margin:1.5mm 0; direction:rtl;">
            شكراً لتسوقكم معنا<br/>
            يرجى الاحتفاظ بالإيصال للاستبدال
        </div>
        
        <div style="text-align:center; font-size:8.5px; margin:1.5mm 0;">
            Keep Bill For Exchange Within 15 Days
        </div>
        
        <div style="text-align:center; font-size:9px; font-weight:bold; margin:1.5mm 0;">
            &lt;&lt; You Saved Amount RO: 0.000 &gt;&gt;
        </div>
        
        <div style="border-top:1px solid black; margin-top:2mm; padding-top:1mm;">
            <div style="text-align:center; font-size:7px; color:#666;">
                Printed by <t t-esc="props.header.cashier"/> at <t t-esc="env.services.pos.config.name"/> on<br/>
                <t t-esc="new Date().toLocaleDateString('en-GB')"/> <t t-esc="new Date().toLocaleTimeString('en-US', {hour: '2-digit', minute: '2-digit', hour12: true})"/>
            </div>
        </div>
    </div>
    
</div>
        ]]></field>
    </record>
</odoo>